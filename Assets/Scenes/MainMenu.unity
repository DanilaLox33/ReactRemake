--- !u!114 &1006648613
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1006648611}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c82c66dde8b4b3b4783cb3eb7edb6fae, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  line: {fileID: 828298988}
  showTime: 20
  _randomNews:
  - "BREAKING: \u041F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u0437\u0435\u043C\u043B\u0435\u0442\u0440\u044F\u0441\u0435\u043D\u0438\u0435!
    \u041F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442 \u043D\u0430\u0437\u043D\u0430\u0447\u0430\u0435\u0442
    \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0435 \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E"
  - "\u0421\u0442\u0440\u0430\u043D\u0430 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0432 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438,
    \u0438 \u0432\u0441\u0435 \u0433\u043B\u0430\u0437\u0430 \u0443\u0441\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u044B
    \u043D\u0430 \u043D\u043E\u0432\u043E\u0435 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E!"
  - "\u0421\u0435\u0439\u0447\u0430\u0441 \u043F\u043E \u0432\u0441\u0435\u0439 \u0441\u0442\u0440\u0430\u043D\u0435
    \u0432\u0435\u0434\u0443\u0442\u0441\u044F \u0441\u043F\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B, \u0438 \u0442\u044B\u0441\u044F\u0447\u0438
    \u043B\u044E\u0434\u0435\u0439 \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F
    \u0432 \u043E\u0436\u0438\u0434\u0430\u043D\u0438\u0438 \u043D\u043E\u0432\u043E\u0441\u0442\u0435\u0439
    \u043E \u0441\u0432\u043E\u0438\u0445 \u0431\u043B\u0438\u0437\u043A\u0438\u0445"
  - "\u041F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442 \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u043D\u0443\u043B,
    \u0447\u0442\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0435\u0439
    \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0430
    \u0441\u0442\u0430\u043D\u0435\u0442 \u043E\u043A\u0430\u0437\u0430\u043D\u0438\u0435
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0438 \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u0432\u0448\u0438\u043C
    \u0438 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0434\u043E\u0432\u0435\u0440\u0438\u044F \u0433\u0440\u0430\u0436\u0434\u0430\u043D
    \u043A \u0432\u043B\u0430\u0441\u0442\u0438"
