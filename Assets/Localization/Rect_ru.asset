  - m_Id: 14527393461088357
    m_Localized: "\u042D\u0445, \u0441\u044E\u0434\u0430 \u0431\u044B \u0432 \u0441\u0443\u043C\u043C\u0443
      \u043D\u043E\u043B\u0438\u043A \u0434\u043E\u043F\u0438\u0441\u0430\u0442\u044C\u2026 "
    m_Metadata:
      m_Items: []
  - m_Id: 14527393461088358
    m_Localized: "\u042D\u0445, \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A,
      \u0441 \u0442\u043E\u0431\u043E\u0439 \u043A\u0430\u0448\u0438 \u043D\u0435
      \u0441\u0432\u0430\u0440\u0438\u0448\u044C\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 24356271637573634
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F  \u0432\u044B\u0448\u043B\u0430, 
      \u0434\u0432\u0435\u0440\u044C \u0437\u0430\u0445\u043B\u043E\u043F\u043D\u0443\u043B\u0430\u0441\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 24356271637573633
    m_Localized: "\u0414\u043E\u043C\u0438\u043D\u0438\u043A \u0432\u044B\u0448\u0435\u043B,
      \u0434\u0432\u0435\u0440\u044C \u0437\u0430\u0445\u043B\u043E\u043F\u043D\u0443\u043B\u0430\u0441\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 24356271637573632
    m_Localized: "\u0412\u0438\u0442\u043E \u0432\u044B\u0448\u0435\u043B,  \u0434\u0432\u0435\u0440\u044C
      \u0437\u0430\u0445\u043B\u043E\u043F\u043D\u0443\u043B\u0430\u0441\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 14527393461088362
    m_Localized: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E! \u0421 \u0442\u0430\u043A\u0438\u043C\u0438
      \u0434\u0435\u043D\u044C\u0433\u0430\u043C\u0438 \u0432\u0441\u0451 \u0441\u0434\u0435\u043B\u0430\u0435\u043C
      \u0432 \u043B\u0443\u0447\u0448\u0435\u043C \u0432\u0438\u0434\u0435! "
    m_Metadata:
      m_Items: []
  - m_Id: 14527393461088363
    m_Localized: "\u041C\u0430\u043B\u043E\u0432\u0430\u0442\u043E, \u043A\u043E\u043D\u0435\u0447\u043D\u043E,
      \u043D\u043E \u043C\u044B \u0441\u043F\u0440\u0430\u0432\u0438\u043C\u0441\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 14527393461088364
    m_Localized: "\u042D\u0442\u043E \u0431\u043E\u043B\u044C\u0448\u0430\u044F \u043E\u0448\u0438\u0431\u043A\u0430,
      \u0411\u043E\u0441\u0441."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185797
    m_Localized: "\u041D\u0435\u0444\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185798
    m_Localized: "\u0417\u0430\u0432\u043E\u0434"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185799
    m_Localized: "\u0410\u043F\u0435\u043B\u044C\u0441\u0438\u043D\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185800
    m_Localized: "\u0421\u041F\u0413"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185801
    m_Localized: "\u0421\u0442\u0430\u043B\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185802
    m_Localized: "\u0426\u0435\u043C\u0435\u043D\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185809
    m_Localized: "\u0412\u044B\u0448\u043A\u0438 \u0441\u043E\u0442\u043E\u0432\u043E\u0439
      \u0441\u0432\u044F\u0437\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185810
    m_Localized: "\u0416\u0435\u043B\u0435\u0437\u043D\u0430\u044F \u0434\u043E\u0440\u043E\u0433\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185811
    m_Localized: "\u0416\u0438\u043B\u044C\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185812
    m_Localized: "\u0424\u0435\u0440\u043C\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185813
    m_Localized: "\u0421\u0435\u043B\u044C\u0441\u043A\u043E\u0435 \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185814
    m_Localized: "\u042F\u0440\u043C\u0430\u0440\u043A\u0438 \u0438 \u0440\u044B\u043D\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185821
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u043D\u0430\u0448\u043B\u0430
      \u0445\u043E\u0440\u043E\u0448\u0435\u0433\u043E \u043F\u043E\u0434\u0440\u044F\u0434\u0447\u0438\u043A\u0430
      \u0434\u043B\u044F \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044F
      \u043D\u0435\u0444\u0442\u044F\u043D\u044B\u0445 \u0432\u044B\u0448\u0435\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185822
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u043E
      \u0437\u0430\u043A\u043B\u044E\u0447\u0438\u043B\u0430 \u043A\u043E\u043D\u0442\u0440\u0430\u043A\u0442
      \u0441 \u043D\u0430\u0434\u0451\u0436\u043D\u043E\u0439 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0435\u0439
      \u0438\u0437 \u0422\u0443\u0440\u0438\u043D\u0430. \u0427\u0435\u0440\u0435\u0437
      \u043D\u0435\u0434\u0435\u043B\u044E \u0446\u0435\u0445\u0430 \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438
      \u0432 \u043F\u043E\u043B\u043D\u0443\u044E \u0441\u0438\u043B\u0443, \u0430
      \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
      \u0446\u0435\u0445\u0430 \u0432\u044B\u0440\u043E\u0441\u043B\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185823
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430
      \u043D\u043E\u0432\u044B\u0435 \u043B\u0438\u043D\u0438\u0438 \u0437\u0430
      \u0441\u0447\u0438\u0442\u0430\u043D\u043D\u044B\u0435 \u0434\u043D\u0438,
      \u0443\u0441\u043F\u0435\u043B\u0430 \u0441\u043F\u0430\u0441\u0442\u0438 \u0431\u043E\u043B\u044C\u0448\u0443\u044E
      \u0447\u0430\u0441\u0442\u044C \u0443\u0440\u043E\u0436\u0430\u044F. \u041F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E
      \u0441\u043E\u043A\u0430 \u0432\u044B\u0440\u043E\u0441\u043B\u043E, \u0430
      \u0437\u0430\u0440\u0443\u0431\u0435\u0436\u043D\u044B\u0435 \u043F\u0430\u0440\u0442\u043D\u0451\u0440\u044B
      \u0432\u044B\u0441\u0442\u0440\u043E\u0438\u043B\u0438\u0441\u044C \u0432 \u043E\u0447\u0435\u0440\u0435\u0434\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185824
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u043D\u0430\u043D\u044F\u043B\u0430
      \u043A\u0440\u0438\u043E-\u0441\u043F\u0435\u0446\u043E\u0432 \u0441 \u0441\u0435\u0432\u0435\u0440\u0430,
      \u0432\u0441\u0451 \u043F\u043E\u0447\u0438\u043D\u0438\u043B\u0438 \u0432
      \u0440\u0435\u043A\u043E\u0440\u0434\u043D\u044B\u0435 \u0441\u0440\u043E\u043A\u0438.
      \u0423\u0442\u0435\u0447\u043A\u0430 \u0443\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0430,
      \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0441\u0442\u0430\u0431\u0438\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B\u043E\u0441\u044C,
      \u0430 \u044F\u043F\u043E\u043D\u0446\u044B \u043F\u0440\u0438\u0441\u043B\u0430\u043B\u0438
      \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u0444\u0430\u043A\u0441 \u0438 \u043F\u0440\u043E\u0434\u043B\u0438\u043B\u0438
      \u043A\u043E\u043D\u0442\u0440\u0430\u043A\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185825
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u0432\u044B\u0436\u0430\u043B\u0430
      \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C \u0438\u0437 \u0431\u044E\u0434\u0436\u0435\u0442\u0430:
      \u043F\u0440\u0438\u0432\u0435\u0437\u043B\u0430 \u0441\u0442\u0430\u043D\u043A\u0438,
      \u043D\u0430\u043B\u0430\u0434\u0438\u043B\u0430 \u043B\u0438\u043D\u0438\u0438,
      \u0438 \u043F\u0440\u043E\u043A\u0430\u0442 \u043F\u043E\u0448\u0451\u043B
      \u0440\u043E\u0432\u043D\u044B\u0439, \u043A\u0430\u043A \u043F\u043E \u043C\u0430\u0441\u043B\u0443.
      \u041A\u043E\u043C\u0431\u0438\u043D\u0430\u0442 \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u043B,
      \u0433\u0440\u0430\u0444\u0438\u043A\u0438 \u043D\u0430\u0433\u043D\u0430\u043B\u0438,
      \u043F\u0440\u0438\u0431\u044B\u043B\u044C \u0432\u044B\u0440\u043E\u0441\u043B\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185826
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u043D\u0435 \u043F\u043E\u0434\u0432\u0435\u043B\u0430
      \u2014 \u043D\u0430 \u0437\u0430\u0432\u043E\u0434\u0435 \u043F\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C
      \u043D\u043E\u0432\u044B\u0435 \u0441\u0438\u043B\u043E\u0441\u044B, \u043C\u043E\u043D\u0442\u0430\u0436
      \u0448\u0451\u043B \u043A\u0440\u0443\u0433\u043B\u043E\u0441\u0443\u0442\u043E\u0447\u043D\u043E.
      \u0421\u044B\u0440\u044C\u0451 \u0442\u0435\u043F\u0435\u0440\u044C \u0445\u0440\u0430\u043D\u0438\u0442\u0441\u044F
      \u0432 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0445 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445,
      \u0430 \u043E\u0431\u044A\u0451\u043C\u044B \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0430
      \u0432\u044B\u0440\u043E\u0441\u043B\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185833
    m_Localized: "\u0412\u0438\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u043B
      \u0437\u0430\u043A\u0443\u043F\u043A\u0443 \u0442\u0435\u043B\u0435\u043A\u043E\u043C\u043C\u0443\u043D\u0438\u043A\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185834
    m_Localized: "\u0412\u0438\u0442\u043E \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B
      \u043A\u043E\u043D\u0442\u0440\u0430\u043A\u0442\u044B \u043D\u0430 \u0440\u0435\u043C\u043E\u043D\u0442
      \u0436\u0435\u043B\u0435\u0437\u043D\u043E\u0434\u043E\u0440\u043E\u0436\u043D\u044B\u0445
      \u043F\u0443\u0442\u0435\u0439 \u0438 \u0437\u0430\u043A\u0443\u043F\u043A\u0443
      \u043D\u043E\u0432\u044B\u0445 \u0432\u0430\u0433\u043E\u043D\u043E\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185835
    m_Localized: "\u0412\u0438\u0442\u043E \u0430\u043A\u0442\u0438\u0432\u043D\u043E
      \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0437\u0430\u043A\u0443\u043F\u043A\u043E\u0439
      \u0438 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u043E\u0439 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
      \u043C\u043E\u0434\u0443\u043B\u044C\u043D\u044B\u0445 \u0434\u043E\u043C\u043E\u0432
      \u0434\u043B\u044F \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u0432\u0448\u0438\u0445
      \u0441\u0435\u043C\u0435\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185836
    m_Localized: "\u0412\u0438\u0442\u043E \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B
      \u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0439 \u0440\u0435\u043C\u043E\u043D\u0442
      \u043A\u0430\u043D\u0430\u043B\u043E\u0432 \u0438 \u0437\u0430\u043A\u0443\u043F\u0438\u043B
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u0434\u043B\u044F
      \u0441\u0438\u0441\u0442\u0435\u043C \u043F\u043E\u043B\u0438\u0432\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185837
    m_Localized: "\u0412\u0438\u0442\u043E \u0430\u043A\u0442\u0438\u0432\u043D\u043E
      \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0437\u0430\u043A\u0443\u043F\u043A\u043E\u0439
      \u0438 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u043E\u0439 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
      \u043C\u043E\u0434\u0443\u043B\u044C\u043D\u044B\u0445 \u0434\u043E\u043C\u043E\u0432
      \u0434\u043B\u044F \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u0432\u0448\u0438\u0445
      \u0441\u0435\u043C\u0435\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185838
    m_Localized: "\u0412\u0438\u0442\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
      \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0435\u0439 \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
      \u0442\u043E\u0440\u0433\u043E\u0432\u044B\u0445 \u043F\u043B\u043E\u0449\u0430\u0434\u043E\u043A
      \u0438 \u0434\u043E\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B\u0441\u044F
      \u043E \u043B\u044C\u0433\u043E\u0442\u043D\u043E\u0439 \u0430\u0440\u0435\u043D\u0434\u0435
      \u0434\u043B\u044F \u043C\u0435\u043B\u043A\u0438\u0445 \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185845
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u043D\u0435 \u043F\u0440\u0438\u0442\u0440\u043E\u043D\u0443\u043B\u0430\u0441\u044C
      \u043A \u0432\u044B\u0448\u043A\u0430\u043C \u0438 \u0432\u044B\u0432\u0435\u043B\u0430
      \u0432\u0441\u0435 \u0434\u0435\u043D\u044C\u0433\u0438 \u0432 \u043E\u0444\u0444\u0448\u043E\u0440.
      \u0411\u0430\u0440\u0440\u0435\u043B\u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B\u0438
      \u043F\u0443\u0441\u0442\u043E\u0432\u0430\u0442\u044C, \u0430 \u043F\u043E\u043A\u0443\u043F\u0430\u0442\u0435\u043B\u0438
      \u0437\u043B\u0438\u0442\u044C\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185846
    m_Localized: "\u0414\u0435\u043D\u044C\u0433\u0438 \u0443\u0448\u043B\u0438 \u043D\u0430
      \u201C\u0431\u0443\u043C\u0430\u0436\u043D\u0443\u044E\u201D \u043C\u043E\u0434\u0435\u0440\u043D\u0438\u0437\u0430\u0446\u0438\u044E.
      \u0411\u044C\u044F\u043D\u043A\u0430 \u0441\u0432\u044F\u0437\u0430\u043B\u0430\u0441\u044C
      \u0441 \u0441\u043E\u043C\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
      \u043F\u043E\u0434\u0440\u044F\u0434\u0447\u0438\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
      \u043F\u0440\u043E\u043F\u0430\u043B \u043F\u043E\u0441\u043B\u0435 \u0430\u0432\u0430\u043D\u0441\u0430.
      \u0417\u0430\u0432\u043E\u0434 \u0432\u0441\u0442\u0430\u043B \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
      \u0440\u0430\u0431\u043E\u0447\u0438\u0435 \u0431\u0430\u0441\u0442\u0443\u044E\u0442,
      \u0433\u0440\u0430\u0444\u0438\u043A\u0438 \u0441\u043E\u0440\u0432\u0430\u043D\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185847
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u043D\u0435 \u043A\u0443\u043F\u0438\u043B\u0430
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435, \u0430
      \u0441\u043F\u0438\u0441\u0430\u043B\u0430 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430
      \u043D\u0430 \u043D\u0435\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0435
      \"\u043E\u0445\u043B\u0430\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
      \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438\". \u0410\u043F\u0435\u043B\u044C\u0441\u0438\u043D\u044B
      \u0441\u0433\u043D\u0438\u043B\u0438 \u043F\u0440\u044F\u043C\u043E \u043D\u0430
      \u0441\u043A\u043B\u0430\u0434\u0435. \u0420\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044F
      \u043F\u043E\u0434\u043C\u043E\u0447\u0435\u043D\u0430, \u043A\u043E\u043D\u0442\u0440\u0430\u043A\u0442\u044B
      \u0441 \u044E\u0436\u0430\u043D\u0430\u043C\u0438 \u0440\u0430\u0437\u043E\u0440\u0432\u0430\u043D\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185848
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u0434\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0430\u0441\u044C
      \u0441 \u0444\u0438\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u0444\u0438\u0440\u043C\u043E\u0439
      \u201CArktika Gas Tech\u201D, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0438\u0441\u0447\u0435\u0437\u043B\u0430
      \u0441\u0440\u0430\u0437\u0443 \u043F\u043E\u0441\u043B\u0435 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430.
      \u0420\u0435\u0437\u0435\u0440\u0432\u0443\u0430\u0440 \u043B\u043E\u043F\u043D\u0443\u043B
      \u0447\u0435\u0440\u0435\u0437 \u0442\u0440\u0438 \u0434\u043D\u044F. \u0423\u0431\u044B\u0442\u043A\u0438
      \u043E\u0433\u0440\u043E\u043C\u043D\u044B, \u044D\u043A\u0441\u043F\u043E\u0440\u0442
      \u0441\u043E\u0440\u0432\u0430\u043D, \u0430\u0437\u0438\u0430\u0442\u0441\u043A\u0438\u0435
      \u043F\u0430\u0440\u0442\u043D\u0451\u0440\u044B \u0433\u043E\u0442\u043E\u0432\u044F\u0442
      \u0438\u0441\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185849
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u0441\u0432\u044F\u0437\u0430\u043B\u0430\u0441\u044C
      \u0441 \u043F\u0435\u0440\u0435\u043A\u0443\u043F\u0449\u0438\u043A\u0430\u043C\u0438,
      \u0437\u0430\u043F\u043B\u0430\u0442\u0438\u043B\u0430 \u0430\u0432\u0430\u043D\u0441
      \u2014 \u0438 \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C \u0441 \u043F\u0443\u0441\u0442\u044B\u043C\u0438
      \u044F\u0449\u0438\u043A\u0430\u043C\u0438. \u041F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E
      \u0432\u0441\u0442\u0430\u043B\u043E \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
      \u043A\u043E\u043D\u0442\u0440\u0430\u043A\u0442\u044B \u0441\u043E\u0440\u0432\u0430\u043D\u044B,
      \u0430 \u0432 \u0446\u0435\u0445\u0430\u0445 \u0441\u043B\u044B\u0448\u043D\u043E
      \u0442\u043E\u043B\u044C\u043A\u043E \u044D\u0445\u043E \u043D\u0435\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185850
    m_Localized: "\u0412\u044B\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0435 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430
      \u0411\u044C\u044F\u043D\u043A\u0430 \u043D\u0430\u043F\u0440\u0430\u0432\u0438\u043B\u0430
      \u0442\u0430\u0439\u043A\u043E\u043C \u0432 \u043F\u043E\u0434\u043F\u043E\u043B\u044C\u043D\u0443\u044E
      \u0441\u0435\u0442\u044C \u043F\u043E\u0441\u0442\u0430\u0432\u043E\u043A \u0434\u043B\u044F
      \"\u0440\u0430\u0431\u043E\u0447\u0435\u0433\u043E \u0444\u0440\u043E\u043D\u0442\u0430\".
      \u0421\u043A\u043B\u0430\u0434 \u0442\u0430\u043A \u0438 \u043D\u0435 \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F,
      \u0446\u0435\u043C\u0435\u043D\u0442 \u043E\u0442\u0441\u044B\u0440\u0435\u043B,
      \u0441\u0442\u0440\u043E\u0439\u043A\u0438 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438\u0441\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185857
    m_Localized: "\u0412\u0438\u0442\u043E \u0431\u044B\u043B \u0437\u0430\u043C\u0435\u0447\u0435\u043D
      \u0432 \u0441\u0442\u0430\u0440\u043E\u043C \u0441\u043A\u043B\u0430\u0434\u0435
      \u0441 \u043E\u0440\u0443\u0436\u0438\u0435\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185858
    m_Localized: "\u0412\u0438\u0442\u043E \u0442\u0430\u0439\u043D\u043E \u043F\u0440\u043E\u0434\u0430\u0432\u0430\u043B
      \u0441\u0442\u0440\u043E\u0439\u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B
      \u043D\u0430 \u0447\u0451\u0440\u043D\u043E\u043C \u0440\u044B\u043D\u043A\u0435
      \u043C\u0435\u0441\u0442\u043D\u044B\u043C \u0434\u0435\u043B\u044C\u0446\u0430\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185859
    m_Localized: "\u0412\u0438\u0442\u043E \u0431\u044B\u043B \u0437\u0430\u043C\u0435\u0447\u0435\u043D
      \u0432 \u043F\u043E\u043A\u0443\u043F\u043A\u0435 \u0434\u0435\u0448\u0451\u0432\u044B\u0445
      \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432 \u043D\u0438\u0437\u043A\u043E\u0433\u043E
      \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0430, \u0430 \u0441\u044D\u043A\u043E\u043D\u043E\u043C\u043B\u0435\u043D\u043D\u044B\u0435
      \u0434\u0435\u043D\u044C\u0433\u0438 \u043F\u0440\u0438\u0441\u0432\u0430\u0438\u0432\u0430\u043B
      \u0441\u0435\u0431\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185860
    m_Localized: "\u0412\u0438\u0442\u043E \u0437\u0430\u043A\u0443\u043F\u0430\u043B
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u043F\u043E
      \u0437\u0430\u0432\u044B\u0448\u0435\u043D\u043D\u044B\u043C \u0446\u0435\u043D\u0430\u043C
      \u0443 \u0441\u0432\u043E\u0435\u0433\u043E \u043A\u0443\u0437\u0435\u043D\u0430,
      \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0432 \u0441 \u043D\u0438\u043C
      \u043F\u0440\u0438\u0431\u044B\u043B\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185861
    m_Localized: "\u0412\u0438\u0442\u043E \u0431\u044B\u043B \u0437\u0430\u043C\u0435\u0447\u0435\u043D
      \u0437\u0430 \u043F\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0440\u0430\u043C\u0438
      \u043E \u043F\u0435\u0440\u0435\u043F\u0440\u043E\u0434\u0430\u0436\u0435 \u0437\u0430\u043A\u0443\u043F\u043B\u0435\u043D\u043D\u043E\u0439
      \u0442\u0435\u0445\u043D\u0438\u043A\u0438 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C
      \u0441\u043F\u0435\u043A\u0443\u043B\u044F\u043D\u0442\u0430\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185862
    m_Localized: "\u0412\u0438\u0442\u043E \u0431\u044B\u043B \u0437\u0430\u043C\u0435\u0447\u0435\u043D
      \u0437\u0430 \u0432\u0437\u0438\u043C\u0430\u043D\u0438\u0435\u043C \u043B\u0438\u0447\u043D\u044B\u0445
      \xAB\u043A\u043E\u043C\u0438\u0441\u0441\u0438\u043E\u043D\u043D\u044B\u0445\xBB
      \u0441 \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u0435\u0439
      \u0437\u0430 \u043B\u0443\u0447\u0448\u0438\u0435 \u043C\u0435\u0441\u0442\u0430
      \u043D\u0430 \u044F\u0440\u043C\u0430\u0440\u043A\u0430\u0445."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185869
    m_Localized: "\u041D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A, \u0432\u0441\u0435
      \u043D\u0435\u0444\u0442\u044F\u043D\u044B\u0435 \u0432\u044B\u0448\u043A\u0438
      \u0432\u0441\u0442\u0430\u043B\u0438, \u043F\u043E\u043A\u0443\u043F\u0430\u0442\u0435\u043B\u0438
      \u043D\u0430\u0448\u0435\u0433\u043E \u0447\u0435\u0440\u043D\u043E\u0433\u043E
      \u0437\u043E\u043B\u043E\u0442\u0430 \u0431\u044C\u044E\u0442 \u0442\u0440\u0435\u0432\u043E\u0433\u0443,
      \u043D\u0443\u0436\u043D\u043E \u0441\u0440\u043E\u0447\u043D\u043E \u0438\u0441\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C
      \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044E."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185870
    m_Localized: "\u041D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A, \u043A\u043E\u043D\u0432\u0435\u0439\u0435\u0440
      \u043D\u0430 \u043D\u0430\u0448\u0435\u043C \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C
      \u043C\u0430\u0448\u0438\u043D\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u043C
      \u0437\u0430\u0432\u043E\u0434\u0435 \u0441\u043D\u043E\u0432\u0430 \u0432\u0441\u0442\u0430\u043B!
      \u041F\u0435\u0440\u0435\u0434\u0430\u0442\u043E\u0447\u043D\u044B\u0435 \u0432\u0430\u043B\u044B
      \u0442\u0440\u0435\u0449\u0430\u0442, \u043A\u0430\u043A \u0441\u0442\u0430\u0440\u044B\u0435
      \u043A\u043E\u0441\u0442\u0438. \u0415\u0441\u043B\u0438 \u043D\u0435 \u043F\u043E\u0447\u0438\u043D\u0438\u043C,
      \u043F\u043E\u0442\u0435\u0440\u044F\u0435\u043C \u0442\u0440\u0438 \u043D\u0435\u0434\u0435\u043B\u0438
      \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185871
    m_Localized: "\u041A\u043E\u043C\u0430\u043D\u0434\u0438\u0440, \u0431\u0435\u0434\u0430
      \u0441 \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u043A\u043E\u0439
      \u0430\u043F\u0435\u043B\u044C\u0441\u0438\u043D\u043E\u0432! \u0417\u0430\u0432\u043E\u0434
      \u043F\u0435\u0440\u0435\u0433\u0440\u0443\u0436\u0435\u043D, \u0447\u0430\u0441\u0442\u044C
      \u0443\u0440\u043E\u0436\u0430\u044F \u0443\u0436\u0435 \u043D\u0430\u0447\u0430\u043B\u0430
      \u043F\u043E\u0440\u0442\u0438\u0442\u044C\u0441\u044F. \u041C\u043E\u0436\u0435\u043C
      \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
      \u043B\u0438\u043D\u0438\u0438 \u0432\u044B\u0436\u0438\u043C\u043A\u0438 \u0441\u043E\u043A\u0430
      \u2014 \u0431\u044B\u0441\u0442\u0440\u043E, \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E
      \u0438 \u0441 \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u043C\u0438
      \u043F\u043E\u0442\u0435\u0440\u044F\u043C\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185872
    m_Localized: "\u041D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A, \u0443
      \u043D\u0430\u0441 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u043D\u0430
      \u0442\u0435\u0440\u043C\u0438\u043D\u0430\u043B\u0435 \u0441\u0436\u0438\u0436\u0435\u043D\u043D\u043E\u0433\u043E
      \u043F\u0440\u0438\u0440\u043E\u0434\u043D\u043E\u0433\u043E \u0433\u0430\u0437\u0430.
      \u041E\u0434\u0438\u043D \u0438\u0437 \u0440\u0435\u0437\u0435\u0440\u0432\u0443\u0430\u0440\u043E\u0432
      \u0434\u0430\u043B \u0442\u0435\u0447\u044C \u2014 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435
      \u043F\u0430\u0434\u0430\u0435\u0442, \u043E\u0431\u044A\u0451\u043C\u044B
      \u043D\u0435\u0434\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u044B,
      \u0430 \u044F\u043F\u043E\u043D\u0446\u044B \u0443\u0436\u0435 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0432\u0430\u044E\u0442!
      \u0415\u0441\u0442\u044C \u0440\u0435\u0448\u0435\u043D\u0438\u0435: \u043F\u0435\u0440\u0435\u0432\u0435\u0441\u0442\u0438
      \u0447\u0430\u0441\u0442\u044C \u0438\u043D\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B
      \u043D\u0430 \u043D\u043E\u0432\u0443\u044E \u043A\u0440\u0438\u043E\u0433\u0435\u043D\u043D\u0443\u044E
      \u0441\u0438\u0441\u0442\u0435\u043C\u0443. \u041D\u0435\u0434\u0451\u0448\u0435\u0432\u043E,
      \u043D\u043E \u043D\u0430\u0434\u0451\u0436\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185873
    m_Localized: "\u041D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A, \u043D\u0430
      \u0441\u0442\u0430\u043B\u0435\u043B\u0438\u0442\u0435\u0439\u043D\u043E\u043C
      \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u0435 \u043F\u0440\u043E\u043A\u0430\u0442\u043D\u044B\u0439
      \u0441\u0442\u0430\u043D \u0441\u0442\u043E\u0438\u0442 \u043A\u0430\u043A
      \u0432\u043A\u043E\u043F\u0430\u043D\u043D\u044B\u0439. \u041F\u043E\u0434\u0448\u0438\u043F\u043D\u0438\u043A\u0438
      \u0432\u044B\u0448\u043B\u0438 \u0438\u0437 \u0441\u0442\u0440\u043E\u044F,
      \u0430 \u043B\u0438\u0441\u0442\u043E\u0432\u0430\u044F \u0441\u0442\u0430\u043B\u044C
      \u043D\u0430\u043C \u0441\u0435\u0439\u0447\u0430\u0441 \u043D\u0443\u0436\u043D\u0430
      \u043A\u0430\u043A \u0432\u043E\u0437\u0434\u0443\u0445 \u2014 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
      \u0434\u043B\u044F \u0432\u043E\u0435\u043D\u043D\u044B\u0445 \u043A\u043E\u043D\u0442\u0440\u0430\u043A\u0442\u043E\u0432.
      \u0423 \u043C\u0435\u043D\u044F \u043D\u0430 \u043F\u0440\u0438\u043C\u0435\u0442\u0435
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u0438\u0437
      \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438, \u043D\u0435 \u043D\u043E\u0432\u043E\u0435,
      \u043D\u043E \u043A\u0440\u0435\u043F\u043A\u043E\u0435. \u041D\u0443\u0436\u043D\u043E
      \u0432\u043B\u043E\u0436\u0438\u0442\u044C\u0441\u044F \u0438 \u043F\u0440\u0438\u0432\u0435\u0437\u0442\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 14528259937185874
    m_Localized: "\u041A\u043E\u043C\u0430\u043D\u0434\u0438\u0440, \u0441\u043A\u043B\u0430\u0434\u044B
      \u043D\u0430 \u0446\u0435\u043C\u0435\u043D\u0442\u043D\u043E\u043C \u0437\u0430\u0432\u043E\u0434\u0435
      \u0442\u0440\u0435\u0449\u0430\u0442 \u043F\u043E \u0448\u0432\u0430\u043C
      \u2014 \u0441\u044B\u0440\u044C\u0451 \u0445\u0440\u0430\u043D\u0438\u0442\u0441\u044F
      \u043F\u043E\u0434 \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u043C \u043D\u0435\u0431\u043E\u043C,
      \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0430 \u0443\u0436\u0435 \u043E\u0442\u0441\u044B\u0440\u0435\u043B\u0430.
      \u0415\u0441\u043B\u0438 \u043D\u0435 \u0432\u043B\u043E\u0436\u0438\u043C
      \u0432 \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0435 \u0441\u0438\u043B\u043E\u0441\u044B
      \u0438 \u0441\u0443\u0448\u0438\u043B\u044C\u043D\u044B\u0435 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438
      \u2014 \u043F\u043E\u0442\u0435\u0440\u044F\u0435\u043C \u0442\u0435\u043C\u043F\u044B
      \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
      \u043F\u043E \u0432\u0441\u0435\u0439 \u0441\u0442\u0440\u0430\u043D\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 24356271637573635
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u0432\u044B\u0448\u043B\u0430,
      \u0434\u0432\u0435\u0440\u044C \u0437\u0430\u0445\u043B\u043E\u043F\u043D\u0443\u043B\u0430\u0441\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259941380097
    m_Localized: "\u0411\u043E\u0441\u0441, \u043F\u043E\u0441\u043B\u0435 \u0437\u0435\u043C\u043B\u0435\u0442\u0440\u044F\u0441\u0435\u043D\u0438\u044F
      \u0431\u043E\u043B\u044C\u0448\u0430\u044F \u0447\u0430\u0441\u0442\u044C \u043E\u0444\u0438\u0441\u043D\u044B\u0445
      \u0437\u0434\u0430\u043D\u0438\u0439 \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u0430.
      \u041C\u043E\u0436\u0435\u0442, \u0441\u0442\u043E\u0438\u0442 \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C
      \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430 \u043D\u0430 \u0432\u044B\u0448\u043A\u0438
      \u0441\u043E\u0442\u043E\u0432\u043E\u0439 \u0441\u0432\u044F\u0437\u0438,
      \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043C \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432
      \u043D\u0430 \u0443\u0434\u0430\u043B\u0451\u043D\u043A\u0443?"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259941380098
    m_Localized: "\u0411\u043E\u0441\u0441, \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F
      \u0441\u043B\u043E\u0436\u043D\u0430\u044F: \u043F\u043E\u0440\u0442\u044B
      \u0438 \u0434\u043E\u0440\u043E\u0433\u0438 \u0441\u0438\u043B\u044C\u043D\u043E
      \u043F\u043E\u0432\u0440\u0435\u0436\u0434\u0435\u043D\u044B, \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u044B
      \u0433\u043D\u0438\u044E\u0442 \u043D\u0430 \u0441\u043A\u043B\u0430\u0434\u0430\u0445.
      \u0427\u0442\u043E \u0435\u0441\u043B\u0438 \u0432\u043B\u043E\u0436\u0438\u0442\u044C\u0441\u044F
      \u0432 \u0440\u0435\u043C\u043E\u043D\u0442 \u0438 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u0435
      \u0436\u0435\u043B\u0435\u0437\u043D\u043E\u0439 \u0434\u043E\u0440\u043E\u0433\u0438?
      \u0422\u0430\u043A \u0441\u043F\u0430\u0441\u0451\u043C \u043F\u043E\u0441\u0442\u0430\u0432\u043A\u0438
      \u0438 \u043D\u0435 \u0434\u0430\u0434\u0438\u043C \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435
      \u0437\u0430\u0433\u043D\u0443\u0442\u044C\u0441\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259941380099
    m_Localized: "\u0411\u043E\u0441\u0441, \u0441\u043E\u0442\u043D\u0438 \u0441\u0435\u043C\u0435\u0439
      \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C \u0431\u0435\u0437 \u0436\u0438\u043B\u044C\u044F
      \u043F\u043E\u0441\u043B\u0435 \u0437\u0435\u043C\u043B\u0435\u0442\u0440\u044F\u0441\u0435\u043D\u0438\u044F.
      \u041F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044E \u043D\u0430\u043F\u0440\u0430\u0432\u0438\u0442\u044C
      \u0431\u044E\u0434\u0436\u0435\u0442 \u043D\u0430 \u0431\u044B\u0441\u0442\u0440\u043E\u0435
      \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
      \u043C\u043E\u0434\u0443\u043B\u044C\u043D\u044B\u0445 \u0434\u043E\u043C\u043E\u0432.
      \u0422\u0430\u043A \u043B\u044E\u0434\u0438 \u0441\u043D\u043E\u0432\u0430
      \u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044E\u0442 \u0441\u0435\u0431\u044F
      \u0432 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438
      \u0438 \u0432\u0435\u0440\u043D\u0443\u0442\u0441\u044F \u043A \u0440\u0430\u0431\u043E\u0442\u0435
      \u2014 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0430 \u043D\u0430\u0447\u043D\u0435\u0442
      \u043E\u0436\u0438\u0432\u0430\u0442\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259941380100
    m_Localized: "\u041D\u0430\u0448\u0438 \u0444\u0435\u0440\u043C\u0435\u0440\u044B
      \u0432 \u043E\u0442\u0447\u0430\u044F\u043D\u0438\u0438, \u0431\u043E\u0441\u0441!
      \u0418\u0440\u0440\u0438\u0433\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0435
      \u043A\u0430\u043D\u0430\u043B\u044B \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u044B,
      \u0443\u0440\u043E\u0436\u0430\u0439 \u043F\u043E\u0434 \u0443\u0433\u0440\u043E\u0437\u043E\u0439.
      \u041C\u043E\u0436\u0435\u0442, \u043F\u0440\u043E\u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u0443\u0435\u043C
      \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
      \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043E\u0440\u043E\u0448\u0435\u043D\u0438\u044F?
      \u0421\u043E\u0445\u0440\u0430\u043D\u0438\u043C \u0443\u0440\u043E\u0436\u0430\u0439,
      \u043B\u044E\u0434\u0435\u0439 \u043F\u0440\u043E\u043A\u043E\u0440\u043C\u0438\u043C
      \u0438 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0443 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u043C!"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259941380101
    m_Localized: "\u041F\u043E\u0441\u043B\u0435 \u0437\u0435\u043C\u043B\u0435\u0442\u0440\u044F\u0441\u0435\u043D\u0438\u044F
      \u043C\u043D\u043E\u0433\u0438\u0435 \u0444\u0435\u0440\u043C\u0435\u0440\u044B
      \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C \u0431\u0435\u0437 \u0442\u0435\u0445\u043D\u0438\u043A\u0438
      \u0438 \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u044F.
      \u0411\u043E\u0441\u0441, \u043C\u043E\u0436\u0435\u0442, \u043D\u0430\u043F\u0440\u0430\u0432\u0438\u043C
      \u0434\u0435\u043D\u044C\u0433\u0438 \u043D\u0430 \u0437\u0430\u043A\u0443\u043F\u043A\u0443
      \u0441\u0435\u043B\u044C\u0445\u043E\u0437\u0442\u0435\u0445\u043D\u0438\u043A\u0438
      \u0438 \u0443\u0434\u043E\u0431\u0440\u0435\u043D\u0438\u0439? \u0412\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043C
      \u0441\u0435\u043B\u044C\u0441\u043A\u043E\u0435 \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u043E
      \u2014 \u043B\u044E\u0434\u0438 \u0441\u043A\u0430\u0436\u0443\u0442 \u0441\u043F\u0430\u0441\u0438\u0431\u043E,
      \u0434\u0430 \u0438 \u0440\u044B\u043D\u043E\u043A \u043E\u0436\u0438\u0432\u0451\u0442!"
    m_Metadata:
      m_Items: []
  - m_Id: 14528259941380102
    m_Localized: "\u0413\u043E\u0440\u043E\u0434 \u043F\u043E\u0447\u0442\u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
      \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D, \u0411\u043E\u0441\u0441!
      \u0414\u0430\u0432\u0430\u0439 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0443\u0435\u043C
      \u044F\u0440\u043C\u0430\u0440\u043A\u0438 \u0438 \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
      \u0440\u044B\u043D\u043A\u0438 \u0432 \u0443\u0446\u0435\u043B\u0435\u0432\u0448\u0438\u0445
      \u0440\u0430\u0439\u043E\u043D\u0430\u0445? \u041F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u043C
      \u043C\u0435\u0441\u0442\u043D\u044B\u0445 \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u0435\u0439
      \u0438 \u043F\u043E\u043C\u043E\u0436\u0435\u043C \u043F\u0440\u043E\u0441\u0442\u044B\u043C
      \u043B\u044E\u0434\u044F\u043C \u043A\u0443\u043F\u0438\u0442\u044C \u0441\u0430\u043C\u043E\u0435
      \u043D\u0443\u0436\u043D\u043E\u0435!"
    m_Metadata:
      m_Items: []
