  - m_Id: 24347940885803012
    m_Localized: "\u041C\u0435\u0434\u0441\u0451\u0441\u0442\u0440\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803013
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043A\u0443\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0430
      \u043F\u043E\u0434\u0440\u044F\u0434\u0447\u0438\u043A\u043E\u0432 \u043F\u043E
      \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044E
      \u0437\u0434\u0430\u043D\u0438\u0439 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0445
      \u0448\u043A\u043E\u043B. "
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803014
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043B\u0438\u0447\u043D\u043E
      \u0441\u043B\u0435\u0434\u0438\u043B\u0430, \u0447\u0442\u043E\u0431\u044B
      \u043D\u043E\u0432\u043E\u0435 \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435
      \u0438 \u043C\u0435\u0434\u0438\u043A\u0430\u043C\u0435\u043D\u0442\u044B \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B\u0438
      \u0432 \u043A\u0430\u0436\u0434\u0443\u044E \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u0443,
      \u0430 \u0432\u0440\u0430\u0447\u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438
      \u043E\u0431\u0435\u0449\u0430\u043D\u043D\u044B\u0435 \u043F\u0440\u0438\u0431\u0430\u0432\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803015
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B\u0430
      \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u043D\u0443\u044E \u043F\u0440\u0438\u0432\u0438\u0432\u043E\u0447\u043D\u0443\u044E
      \u043A\u0430\u043C\u043F\u0430\u043D\u0438\u044E, \u0432\u0430\u043A\u0446\u0438\u043D\u044B
      \u043E\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
      \u0438 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u044B\u043C\u0438,
      \u0430 \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u0437\u0430\u0431\u043E\u043B\u0435\u0432\u0430\u0435\u043C\u043E\u0441\u0442\u0438
      \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u043E\u0448\u0451\u043B
      \u043D\u0430 \u0441\u043F\u0430\u0434."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803016
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B\u0430
      \u0442\u0449\u0430\u0442\u0435\u043B\u044C\u043D\u0443\u044E \u0440\u0435\u0441\u0442\u0430\u0432\u0440\u0430\u0446\u0438\u044E
      \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0445
      \u043A\u043E\u0440\u043F\u0443\u0441\u043E\u0432, \u0437\u0430\u043A\u0443\u043F\u0438\u043B\u0430
      \u043D\u043E\u0432\u043E\u0435 \u0443\u0447\u0435\u0431\u043D\u043E\u0435 \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435
      \u0438 \u0434\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0430\u0441\u044C
      \u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438 \u043B\u0443\u0447\u0448\u0438\u0445
      \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u0432 \u043E\u0431\u0440\u0430\u0442\u043D\u043E
      \u0432 \u0441\u0442\u0440\u0430\u043D\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803017
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u0443\u0441\u043F\u0435\u0448\u043D\u043E
      \u043E\u0442\u043A\u0440\u044B\u043B\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
      \u043D\u043E\u0432\u044B\u0445 \u0434\u0435\u0442\u0441\u043A\u0438\u0445 \u0441\u0430\u0434\u043E\u0432,
      \u043F\u0440\u043E\u0432\u0435\u043B\u0430 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u0440\u0435\u043C\u043E\u043D\u0442 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0445
      \u0437\u0434\u0430\u043D\u0438\u0439 \u0438 \u0434\u043E\u0431\u0438\u043B\u0430\u0441\u044C
      \u043E\u0449\u0443\u0442\u0438\u043C\u043E\u0433\u043E \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u044F
      \u0437\u0430\u0440\u043F\u043B\u0430\u0442 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0442\u0435\u043B\u044F\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803018
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B\u0430
      \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0438
      \u0438 \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u044F \u043A\u0432\u0430\u043B\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438
      \u043C\u0435\u0434\u0441\u0435\u0441\u0442\u0451\u0440, \u0443\u043B\u0443\u0447\u0448\u0438\u043B\u0430
      \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u043F\u0440\u043E\u0436\u0438\u0432\u0430\u043D\u0438\u044F
      \u0438 \u0434\u043E\u0431\u0438\u043B\u0430\u0441\u044C \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
      \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u044F \u0437\u0430\u0440\u043F\u043B\u0430\u0442.
      \u041C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0438\u0439 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B
      \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803019
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u0440\u0430\u0437\u043C\u0435\u0441\u0442\u0438\u043B\u0430
      \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0439
      \u0441\u043E\u0441\u0442\u0430\u0432 \u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
      \u0432 \u043F\u0430\u043B\u0430\u0442\u043A\u0430\u0445, \u0430 \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0435\u0441\u044F
      \u0434\u0435\u043D\u044C\u0433\u0438 \u0432\u044B\u0432\u0435\u043B\u0430 \u0432
      \u043E\u0444\u0448\u043E\u0440. "
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803020
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u0437\u0430\u043A\u0443\u043F\u0438\u043B\u0430
      \u0441\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0435 \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u044B
      \u043F\u043E \u0437\u0430\u0432\u044B\u0448\u0435\u043D\u043D\u043E\u0439 \u0446\u0435\u043D\u0435,
      \u043B\u0435\u043A\u0430\u0440\u0441\u0442\u0432\u0430 \u043E\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C
      \u043F\u0440\u043E\u0441\u0440\u043E\u0447\u0435\u043D\u043D\u044B\u043C\u0438,
      \u0430 \u0432\u0440\u0430\u0447\u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438
      \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0431\u0435\u0449\u0430\u043D\u0438\u044F.
      \u041E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435 \u043E\u0441\u0435\u043B\u043E
      \u0432 \u043A\u0430\u0440\u043C\u0430\u043D\u0430\u0445 \u0435\u0451 \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803021
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043F\u0440\u0438\u043E\u0431\u0440\u0435\u043B\u0430
      \u0434\u0435\u0448\u0451\u0432\u044B\u0435 \u0432\u0430\u043A\u0446\u0438\u043D\u044B
      \u0441\u043E\u043C\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
      \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0430, \u0447\u0430\u0441\u0442\u044C
      \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u0438\u044F \u0437\u0430\u0431\u043E\u043B\u0435\u043B\u0430
      \u043E\u0442 \u043F\u043E\u0431\u043E\u0447\u043D\u044B\u0445 \u044D\u0444\u0444\u0435\u043A\u0442\u043E\u0432,
      \u0430 \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0435\u0441\u044F \u0434\u0435\u043D\u044C\u0433\u0438
      \u0442\u0438\u0445\u043E\u043D\u044C\u043A\u043E \u043E\u0441\u0435\u043B\u0438
      \u043D\u0430 \u0441\u0447\u0435\u0442\u0430\u0445 \u0435\u0451 \u0434\u0430\u0432\u043D\u0435\u0433\u043E
      \u043F\u0440\u0438\u044F\u0442\u0435\u043B\u044F \u0438\u0437-\u0437\u0430
      \u0440\u0443\u0431\u0435\u0436\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803022
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043F\u0440\u043E\u0432\u0435\u043B\u0430
      \u043B\u0438\u0448\u044C \u043A\u043E\u0441\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u0440\u0435\u043C\u043E\u043D\u0442 \u043F\u0430\u0440\u044B \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u0439,
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u0437\u0430\u043A\u0443\u043F\u0438\u043B\u0430
      \u0443\u0441\u0442\u0430\u0440\u0435\u0432\u0448\u0435\u0435 \u0438 \u0441\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0435,
      \u0430 \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C
      \u0434\u0435\u043D\u0435\u0433 \u043D\u0430\u043F\u0440\u0430\u0432\u0438\u043B\u0430
      \u043D\u0430 \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
      \u0448\u0438\u043A\u0430\u0440\u043D\u043E\u0439 \u0432\u0438\u043B\u043B\u044B
      \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u043A\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803023
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043B\u0438\u0448\u044C \u0441\u043B\u0435\u0433\u043A\u0430
      \u043F\u043E\u0434\u043A\u0440\u0430\u0441\u0438\u043B\u0430 \u0444\u0430\u0441\u0430\u0434\u044B,
      \u0437\u0430\u043A\u0443\u043F\u0438\u043B\u0430 \u0441\u0430\u043C\u044B\u0435
      \u0434\u0435\u0448\u0435\u0432\u044B\u0435 \u0438\u0433\u0440\u0443\u0448\u043A\u0438,
      \u0430 \u0432\u043C\u0435\u0441\u0442\u043E \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u044F
      \u0437\u0430\u0440\u043F\u043B\u0430\u0442 \u0443\u0441\u0442\u0440\u043E\u0438\u043B\u0430
      \u043F\u044B\u0448\u043D\u044B\u0439 \u043F\u0440\u0430\u0437\u0434\u043D\u0438\u043A
      \u0434\u043B\u044F \u0441\u0432\u043E\u0438\u0445 \u0432\u043D\u0443\u0447\u0430\u0442
      \u043D\u0430 \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0435\u0441\u044F \u0434\u0435\u043D\u044C\u0433\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803024
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043E\u0442\u043A\u0440\u044B\u043B\u0430
      \u043B\u0438\u0448\u044C \u043D\u043E\u043C\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0435
      \u043A\u0443\u0440\u0441\u044B \u0431\u0435\u0437 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439,
      \u0437\u0430\u043A\u0443\u043F\u0438\u043B\u0430 \u0434\u0435\u0448\u0451\u0432\u0443\u044E
      \u0444\u043E\u0440\u043C\u0443 \u0438 \u0432\u044B\u0434\u0430\u043B\u0430
      \u0435\u0451 \u0437\u0430 \xAB\u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0443
      \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u0430\xBB, \u0430 \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0435\u0441\u044F
      \u0434\u0435\u043D\u044C\u0433\u0438 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0430
      \u043D\u0430 \u0441\u0447\u0435\u0442\u0430 \u0437\u043D\u0430\u043A\u043E\u043C\u044B\u0445
      \u0435\u0439 \u043B\u044E\u0434\u0435\u0439 \u0432 \u0441\u043E\u0441\u0435\u0434\u043D\u0435\u0439
      \u0441\u0442\u0440\u0430\u043D\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803025
    m_Localized: "\u041D\u0430\u0448\u0438 \u0448\u043A\u043E\u043B\u044B \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u044B,
      capoccia. \u0414\u0435\u0442\u043A\u0430\u043C \u043D\u0435\u0433\u0434\u0435
      \u0443\u0447\u0438\u0442\u044C\u0441\u044F \u0438 \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C
      \u043D\u043E\u0432\u044B\u0435 \u0437\u043D\u0430\u043D\u0438\u044F. \u042F
      \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044E \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
      \u0438 \u043E\u0442\u0440\u0435\u0441\u0442\u0430\u0432\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0443\u0446\u0435\u043B\u0435\u0432\u0448\u0438\u0435
      \u0448\u043A\u043E\u043B\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803026
    m_Localized: "\u041E\u0445, \u0434\u043E\u0440\u043E\u0433\u043E\u0439 capoccia,
      \u043D\u0430\u0448\u0438 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u044B \u0441\u043E\u0432\u0441\u0435\u043C
      \u043F\u0440\u0438\u0448\u043B\u0438 \u0432 \u0443\u043F\u0430\u0434\u043E\u043A.
      \u041F\u0430\u0446\u0438\u0435\u043D\u0442\u044B \u043B\u0435\u0436\u0430\u0442
      \u043F\u0440\u044F\u043C\u043E \u0432 \u043A\u043E\u0440\u0438\u0434\u043E\u0440\u0430\u0445,
      \u043C\u0435\u0434\u0438\u043A\u0430\u043C\u0435\u043D\u0442\u043E\u0432 \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u0438\u0447\u0435\u0441\u043A\u0438
      \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442, \u0430 \u0432\u0440\u0430\u0447\u0438
      \u0435\u0434\u0432\u0430 \u0434\u0435\u0440\u0436\u0430\u0442\u0441\u044F \u043D\u0430
      \u043D\u043E\u0433\u0430\u0445 \u043E\u0442 \u0443\u0441\u0442\u0430\u043B\u043E\u0441\u0442\u0438!
      \u042F \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044E \u0441\u0440\u043E\u0447\u043D\u043E
      \u0437\u0430\u043A\u0443\u043F\u0438\u0442\u044C \u043D\u043E\u0432\u043E\u0435
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u0438
      \u043C\u0435\u0434\u0438\u043A\u0430\u043C\u0435\u043D\u0442\u044B \u0438 \u043F\u043E\u0432\u044B\u0441\u0438\u0442\u044C
      \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u044C\u0435 \u0432\u0440\u0430\u0447\u0430\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803027
    m_Localized: "\u041E\u0439, \u043C\u0438\u043B\u044B\u0439 \u043C\u043E\u0439
      capoccia, \u0431\u0435\u0434\u0430 \u043A\u0430\u043A\u0430\u044F! \u0412 \u0441\u0442\u0440\u0430\u043D\u0435
      \u0443\u0447\u0430\u0441\u0442\u0438\u043B\u0438\u0441\u044C \u0432\u0441\u043F\u044B\u0448\u043A\u0438
      \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u0439, \u043E \u043A\u043E\u0442\u043E\u0440\u044B\u0445
      \u044F \u0438 \u0434\u0443\u043C\u0430\u0442\u044C-\u0442\u043E \u0437\u0430\u0431\u044B\u043B\u0430
      \u0441 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438! \u0414\u0435\u0442\u043A\u0438
      \u0438 \u0441\u0442\u0430\u0440\u0438\u0447\u043A\u0438 \u0431\u0435\u0437\u0437\u0430\u0449\u0438\u0442\u043D\u044B
      \u043F\u0435\u0440\u0435\u0434 \u044D\u0442\u0438\u043C\u0438 \u0432\u0438\u0440\u0443\u0441\u0430\u043C\u0438,
      \u0430 \u0432\u0430\u043A\u0446\u0438\u043D \u0443 \u043D\u0430\u0441 \u043A\u043E\u0442
      \u043D\u0430\u043F\u043B\u0430\u043A\u0430\u043B, \u043D\u0443\u0436\u043D\u044B
      \u043D\u043E\u0432\u044B\u0435 \u0437\u0430\u043A\u0443\u043F\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803028
    m_Localized: "\u0410\u0445, capoccia \u043C\u043E\u0439 \u0434\u043E\u0440\u043E\u0433\u043E\u0439,
      \u0441\u0435\u0440\u0434\u0435\u0447\u043A\u043E \u0431\u043E\u043B\u0438\u0442
      \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C, \u043A\u0430\u043A \u043D\u0430\u0448\u0430
      \u043C\u043E\u043B\u043E\u0434\u0451\u0436\u044C \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0441\u044F
      \u0443\u0447\u0438\u0442\u044C\u0441\u044F, \u0430 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u044B
      \u043F\u043E\u0447\u0442\u0438 \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u044B!
      \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0431\u0435\u0433\u0443\u0442
      \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0443, \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u0438
      \u043F\u0440\u043E\u0442\u0435\u043A\u0430\u044E\u0442, \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B
      \u043D\u0435 \u043C\u043E\u0433\u0443\u0442 \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C
      \u0434\u043E\u0441\u0442\u043E\u0439\u043D\u043E\u0433\u043E \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F. "
    m_Metadata:
      m_Items: []
  - m_Id: 24347940885803029
    m_Localized: "\u041E\u0439, capoccia, \u0434\u0435\u0442\u0438\u0448\u043A\u0438-\u0442\u043E
      \u0441\u043E\u0432\u0441\u0435\u043C \u0431\u0435\u0437 \u043F\u0440\u0438\u0441\u043C\u043E\u0442\u0440\u0430!
      \u0414\u0435\u0442\u0441\u043A\u0438\u0435 \u0441\u0430\u0434\u044B \u0443
      \u043D\u0430\u0441 \u043F\u0435\u0440\u0435\u043F\u043E\u043B\u043D\u0435\u043D\u044B,
      \u043A\u0440\u043E\u0432\u0430\u0442\u043E\u043A \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442,
      \u0438\u0433\u0440\u0443\u0448\u043A\u0438 \u0441\u043B\u043E\u043C\u0430\u043D\u044B,
      \u0430 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0442\u0435\u043B\u0438 \u0440\u0430\u0437\u0431\u0435\u0433\u0430\u044E\u0442\u0441\u044F,
      \u043D\u0435 \u0432\u044B\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u044F \u043D\u0430\u0433\u0440\u0443\u0437\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 24347940889997312
    m_Localized: "\u041E\u0445, capoccia, \u0443 \u043D\u0430\u0441 \u0436\u0435
      \u0432 \u0441\u0442\u0440\u0430\u043D\u0435 \u043F\u043E\u0447\u0442\u0438
      \u0441\u043E\u0432\u0441\u0435\u043C \u043D\u0435 \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C
      \u043A\u0432\u0430\u043B\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
      \u043C\u0435\u0434\u0441\u0435\u0441\u0442\u0451\u0440! \u0414\u0435\u0432\u043E\u0447\u043A\u0438
      \u043F\u0430\u0448\u0443\u0442 \u0434\u043D\u0451\u043C \u0438 \u043D\u043E\u0447\u044C\u044E,
      \u0430 \u043C\u043D\u043E\u0433\u0438\u0435 \u0443\u0436\u0435 \u0443\u0435\u0437\u0436\u0430\u044E\u0442
      \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0443 \u2013 \u0442\u0430\u043C
      \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u043B\u0443\u0447\u0448\u0435 \u0438
      \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u044B \u0432\u044B\u0448\u0435. "
    m_Metadata:
      m_Items: []
  - m_Id: 24347940889997313
    m_Localized: "\u0420\u043E\u0434\u043D\u043E\u0439 \u043C\u043E\u0439, \u0441\u043F\u0430\u0441\u0438\u0431\u043E
      \u0437\u0430 \u0449\u0435\u0434\u0440\u043E\u0441\u0442\u044C, \u0442\u0435\u043F\u0435\u0440\u044C
      \u043C\u044B \u0442\u043E\u0447\u043D\u043E \u0441\u043F\u0440\u0430\u0432\u0438\u043C\u0441\u044F! "
    m_Metadata:
      m_Items: []
  - m_Id: 24347940889997314
    m_Localized: "\u042D\u0442\u043E\u0433\u043E \u043E\u0447\u0435\u043D\u044C \u043C\u0430\u043B\u043E
      \u0434\u043B\u044F \u043D\u0430\u0448\u0438\u0445 \u043D\u0443\u0436\u0434,
      \u043C\u043E\u0439 \u0434\u043E\u0440\u043E\u0433\u043E\u0439\u2026 "
    m_Metadata:
      m_Items: []
  - m_Id: 24347940889997315
    m_Localized: "\u041E\u0445, \u043C\u0438\u043B\u044B\u0439 \u043C\u043E\u0439,
      \u0437\u0440\u044F \u0442\u044B \u0442\u0430\u043A\u2026 "
    m_Metadata:
      m_Items: []
  - m_Id: 24355636267626496
    m_Localized: "\u041F\u0440\u0435\u0441\u0442\u0443\u043F\u043D\u043E\u0441\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 24355636296986624
    m_Localized: "\u0413\u0440\u0430\u043D\u0438\u0446\u0430"
    m_Metadata:
