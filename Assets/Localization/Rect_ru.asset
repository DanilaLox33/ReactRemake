  m_TableData:
  - m_Id: 5503787761664
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442
      \u043D\u0430\u043F\u0440\u0430\u0432\u0438\u0442\u044C \u0440\u0435\u0441\u0443\u0440\u0441\u044B
      \u043D\u0430 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
      \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0443\u0446\u0435\u043B\u0435\u0432\u0448\u0438\u0445
      \u0448\u043A\u043E\u043B, \u0447\u0442\u043E\u0431\u044B \u0434\u0435\u0442\u0438
      \u043C\u043E\u0433\u043B\u0438 \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
      \u043A \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0443\u0447\u0451\u0431\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 981162033152
    m_Localized: "\u0412\u044B\u0445\u043E\u0434"
    m_Metadata:
      m_Items: []
  - m_Id: 5503787761665
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043E\u0431\u0435\u0441\u043F\u043E\u043A\u043E\u0435\u043D\u0430
      \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u043C
      \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435\u043C \u0431\u043E\u043B\u044C\u043D\u0438\u0446
      \u0438 \u0441\u0447\u0438\u0442\u0430\u0435\u0442 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u044B\u043C
      \u0441\u0440\u043E\u0447\u043D\u043E \u0437\u0430\u043A\u0443\u043F\u0438\u0442\u044C
      \u043C\u0435\u0434\u0438\u043A\u0430\u043C\u0435\u043D\u0442\u044B, \u043D\u043E\u0432\u043E\u0435
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u0438
      \u043F\u043E\u0432\u044B\u0441\u0438\u0442\u044C \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u044B
      \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0438\u043C \u0440\u0430\u0431\u043E\u0442\u043D\u0438\u043A\u0430\u043C.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 5503787761666
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0430\u0435\u0442
      \u043E \u0432\u0441\u043F\u044B\u0448\u043A\u0430\u0445 \u0434\u0430\u0432\u043D\u043E
      \u0437\u0430\u0431\u044B\u0442\u044B\u0445 \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u0439,
      \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044F \u0441\u0440\u043E\u0447\u043D\u043E
      \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0442\u044C \u0441\u0442\u0440\u0430\u043D\u0443
      \u043D\u043E\u0432\u044B\u043C\u0438 \u043F\u0430\u0440\u0442\u0438\u044F\u043C\u0438
      \u0432\u0430\u043A\u0446\u0438\u043D \u0434\u043B\u044F \u0437\u0430\u0449\u0438\u0442\u044B
      \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0443\u044F\u0437\u0432\u0438\u043C\u044B\u0445
      \u0433\u0440\u0430\u0436\u0434\u0430\u043D \u2013 \u0434\u0435\u0442\u0435\u0439
      \u0438 \u043F\u043E\u0436\u0438\u043B\u044B\u0445.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955968
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
      \u043D\u0430 \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u044B\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
      \u0441 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u043C\u0438,
      \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044F \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
      \u0437\u0434\u0430\u043D\u0438\u044F \u0438 \u0443\u043B\u0443\u0447\u0448\u0438\u0442\u044C
      \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u0442\u0440\u0443\u0434\u0430 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u0432,
      \u0447\u0442\u043E\u0431\u044B \u043C\u043E\u043B\u043E\u0434\u0451\u0436\u044C
      \u0441\u043C\u043E\u0433\u043B\u0430 \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C
      \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
      \u0438 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B\u0430 \u0443\u0435\u0437\u0436\u0430\u0442\u044C
      \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955969
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u0435\u0442
      \u0438\u0437-\u0437\u0430 \u043F\u0435\u0440\u0435\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u044B\u0445
      \u0434\u0435\u0442\u0441\u043A\u0438\u0445 \u0441\u0430\u0434\u043E\u0432,
      \u043D\u0435\u0445\u0432\u0430\u0442\u043A\u0438 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0442\u0435\u043B\u0435\u0439
      \u0438 \u0441\u043B\u043E\u043C\u0430\u043D\u043D\u043E\u0433\u043E \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u044F,
      \u0438 \u0441\u0447\u0438\u0442\u0430\u0435\u0442, \u0447\u0442\u043E \u043D\u0443\u0436\u043D\u043E
      \u0441\u0440\u043E\u0447\u043D\u043E \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C
      \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430 \u043D\u0430 \u0443\u043B\u0443\u0447\u0448\u0435\u043D\u0438\u0435
      \u0443\u0441\u043B\u043E\u0432\u0438\u0439 \u0434\u043B\u044F \u043C\u0430\u043B\u044B\u0448\u0435\u0439
      \u0438 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0442\u0435\u043B\u0435\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955970
    m_Localized: "\u0410\u043C\u0430\u043B\u0438\u044F \u0431\u044C\u0451\u0442 \u0442\u0440\u0435\u0432\u043E\u0433\u0443
      \u0438\u0437-\u0437\u0430 \u043E\u0441\u0442\u0440\u043E\u0439 \u043D\u0435\u0445\u0432\u0430\u0442\u043A\u0438
      \u043A\u0432\u0430\u043B\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
      \u043C\u0435\u0434\u0441\u0435\u0441\u0442\u0451\u0440 \u0438 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442
      \u043F\u043E\u0432\u044B\u0441\u0438\u0442\u044C \u0438\u0445 \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u044B
      \u0438 \u0443\u043B\u0443\u0447\u0448\u0438\u0442\u044C \u0443\u0441\u043B\u043E\u0432\u0438\u044F
      \u0440\u0430\u0431\u043E\u0442\u044B, \u0447\u0442\u043E\u0431\u044B \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
      \u043C\u0430\u0441\u0441\u043E\u0432\u044B\u0439 \u043E\u0442\u044A\u0435\u0437\u0434
      \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u0430 \u0437\u0430 \u0440\u0443\u0431\u0435\u0436.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955971
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0430\u0435\u0442,
      \u0447\u0442\u043E \u043D\u0435\u0444\u0442\u044F\u043D\u044B\u0435 \u0432\u044B\u0448\u043A\u0438
      \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438\u0441\u044C, \u0438
      \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442 \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E
      \u0437\u0430\u043D\u044F\u0442\u044C\u0441\u044F \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435\u043C
      \u0434\u043E\u0431\u044B\u0447\u0438, \u0447\u0442\u043E\u0431\u044B \u043D\u0435
      \u0442\u0435\u0440\u044F\u0442\u044C \u0432\u0430\u0436\u043D\u044B\u0445 \u043A\u043B\u0438\u0435\u043D\u0442\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955972
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u043E\u0431\u0435\u0441\u043F\u043E\u043A\u043E\u0435\u043D\u0430
      \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u043E\u0439 \u043A\u043E\u043D\u0432\u0435\u0439\u0435\u0440\u0430
      \u043D\u0430 \u0433\u043B\u0430\u0432\u043D\u043E\u043C \u043C\u0430\u0448\u0438\u043D\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u043C
      \u0437\u0430\u0432\u043E\u0434\u0435 \u0438 \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0443\u0435\u0442
      \u0441\u0440\u043E\u0447\u043D\u043E \u043E\u0442\u0440\u0435\u043C\u043E\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435, \u0447\u0442\u043E\u0431\u044B
      \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044C \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u044B\u0445
      \u0437\u0430\u0434\u0435\u0440\u0436\u0435\u043A \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955973
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u0441\u043E\u043E\u0431\u0449\u0430\u0435\u0442,
      \u0447\u0442\u043E \u0437\u0430\u0432\u043E\u0434 \u043F\u043E \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u043A\u0435
      \u0430\u043F\u0435\u043B\u044C\u0441\u0438\u043D\u043E\u0432 \u043F\u0435\u0440\u0435\u0433\u0440\u0443\u0436\u0435\u043D,
      \u0438 \u0441\u043E\u0432\u0435\u0442\u0443\u0435\u0442 \u0431\u044B\u0441\u0442\u0440\u043E
      \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
      \u043B\u0438\u043D\u0438\u0438 \u0434\u043B\u044F \u043E\u0442\u0436\u0438\u043C\u0430
      \u0441\u043E\u043A\u0430, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u0435\u0434\u043E\u0442\u0432\u0440\u0430\u0442\u0438\u0442\u044C
      \u043F\u043E\u0442\u0435\u0440\u044E \u0443\u0440\u043E\u0436\u0430\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955974
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u0434\u043E\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442
      \u043E \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u043E\u0439 \u043F\u0440\u043E\u0442\u0435\u0447\u043A\u0435
      \u043D\u0430 \u0442\u0435\u0440\u043C\u0438\u043D\u0430\u043B\u0435 \u0441\u0436\u0438\u0436\u0435\u043D\u043D\u043E\u0433\u043E
      \u043F\u0440\u0438\u0440\u043E\u0434\u043D\u043E\u0433\u043E \u0433\u0430\u0437\u0430
      \u0438 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442 \u043F\u0435\u0440\u0435\u0432\u0435\u0441\u0442\u0438
      \u0447\u0430\u0441\u0442\u044C \u0438\u043D\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B
      \u043D\u0430 \u0431\u043E\u043B\u0435\u0435 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
      \u0438 \u043D\u0430\u0434\u0451\u0436\u043D\u0443\u044E \u043A\u0440\u0438\u043E\u0433\u0435\u043D\u043D\u0443\u044E
      \u0441\u0438\u0441\u0442\u0435\u043C\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955975
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
      \u043D\u0430 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
      \u043F\u043E\u043B\u043E\u043C\u043A\u0443 \u043F\u0440\u043E\u043A\u0430\u0442\u043D\u043E\u0433\u043E
      \u0441\u0442\u0430\u043D\u0430 \u043D\u0430 \u0441\u0442\u0430\u043B\u0435\u043B\u0438\u0442\u0435\u0439\u043D\u043E\u043C
      \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u0435 \u0438 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442
      \u0437\u0430\u043A\u0443\u043F\u0438\u0442\u044C \u043F\u0440\u043E\u0447\u043D\u043E\u0435
      \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0435 \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435,
      \u0447\u0442\u043E\u0431\u044B \u043D\u0435 \u0441\u043E\u0440\u0432\u0430\u0442\u044C
      \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0435 \u0432\u0430\u0436\u043D\u044B\u0445
      \u0432\u043E\u0435\u043D\u043D\u044B\u0445 \u0437\u0430\u043A\u0430\u0437\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955976
    m_Localized: "\u0411\u044C\u044F\u043D\u043A\u0430 \u043E\u0431\u0435\u0441\u043F\u043E\u043A\u043E\u0435\u043D\u0430
      \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435\u043C \u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F
      \u0441\u044B\u0440\u044C\u044F \u043D\u0430 \u0446\u0435\u043C\u0435\u043D\u0442\u043D\u043E\u043C
      \u0437\u0430\u0432\u043E\u0434\u0435 \u0438 \u0441\u0447\u0438\u0442\u0430\u0435\u0442
      \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u044B\u043C \u0438\u043D\u0432\u0435\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u0432 \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
      \u043D\u043E\u0432\u044B\u0445 \u0441\u0438\u043B\u043E\u0441\u043E\u0432 \u0438
      \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0443 \u0441\u0443\u0448\u0438\u043B\u044C\u043D\u043E\u0433\u043E
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u044F \u0434\u043B\u044F
      \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0438\u044F \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u0438
      \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0440\u0430\u0431\u043E\u0442
      \u043F\u043E \u0432\u0441\u0435\u0439 \u0441\u0442\u0440\u0430\u043D\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955977
    m_Localized: "\u0414\u043E\u043C\u0435\u043D\u0438\u043A \u0431\u0435\u0441\u043F\u043E\u043A\u043E\u0438\u0442
      \u0440\u043E\u0441\u0442 \u043F\u043E\u0434\u0440\u043E\u0441\u0442\u043A\u043E\u0432\u043E\u0439
      \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043D\u043E\u0441\u0442\u0438, \u0438
      \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442 \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u043E\u0442\u0440\u044F\u0434\u044B \u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0439
      \u043F\u043E\u043B\u0438\u0446\u0438\u0438, \u0447\u0442\u043E\u0431\u044B
      \u043D\u0430\u0432\u0435\u0441\u0442\u0438 \u043F\u043E\u0440\u044F\u0434\u043E\u043A
      \u043D\u0430 \u0443\u043B\u0438\u0446\u0430\u0445."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955978
    m_Localized: "\u0414\u043E\u043C\u0435\u043D\u0438\u043A \u0441\u0447\u0438\u0442\u0430\u0435\u0442,
      \u0447\u0442\u043E \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
      \u0441\u0440\u043E\u0447\u043D\u043E \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
      \u0433\u0440\u0430\u043D\u0438\u0446\u0443, \u0443\u0441\u0438\u043B\u0438\u0432
      \u043F\u0430\u0442\u0440\u0443\u043B\u0438 \u0438 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C\u043D\u043E-\u043F\u0440\u043E\u043F\u0443\u0441\u043A\u043D\u044B\u0435
      \u043F\u0443\u043D\u043A\u0442\u044B, \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u0449\u0438\u0442\u0438\u0442\u044C\u0441\u044F
      \u043E\u0442 \u043C\u0430\u0440\u043E\u0434\u0451\u0440\u043E\u0432 \u0438
      \u043D\u0435\u043A\u043E\u043D\u0442\u0440\u043E\u043B\u0438\u0440\u0443\u0435\u043C\u043E\u0433\u043E
      \u043F\u043E\u0442\u043E\u043A\u0430 \u0431\u0435\u0436\u0435\u043D\u0446\u0435\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955979
    m_Localized: "\u0414\u043E\u043C\u0435\u043D\u0438\u043A \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0430\u0435\u0442,
      \u0447\u0442\u043E \u0432\u043E\u0435\u043D\u043D\u0430\u044F \u0442\u0435\u0445\u043D\u0438\u043A\u0430
      \u043F\u0440\u0438\u0448\u043B\u0430 \u0432 \u043D\u0435\u0433\u043E\u0434\u043D\u043E\u0441\u0442\u044C,
      \u0438 \u043F\u0440\u0438\u0437\u044B\u0432\u0430\u0435\u0442 \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E
      \u043D\u0430\u043F\u0440\u0430\u0432\u0438\u0442\u044C \u0440\u0435\u0441\u0443\u0440\u0441\u044B
      \u043D\u0430 \u0440\u0435\u043C\u043E\u043D\u0442 \u0438 \u0437\u0430\u043A\u0443\u043F\u043A\u0443
      \u0437\u0430\u043F\u0447\u0430\u0441\u0442\u0435\u0439, \u0447\u0442\u043E\u0431\u044B
      \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C
      \u043D\u0430\u0434 \u0440\u0435\u0433\u0438\u043E\u043D\u043E\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955980
    m_Localized: "\u0414\u043E\u043C\u0435\u043D\u0438\u043A\u0430 \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u0435\u0442
      \u043D\u0430 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0438
      \u0438 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
      \u0432\u0438\u0434\u0435\u043E\u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F,
      \u0447\u0442\u043E\u0431\u044B \u0441\u0432\u043E\u0435\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
      \u043F\u0440\u0435\u0441\u0435\u043A\u0430\u0442\u044C \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0438 \u0441\u0442\u0430\u0431\u0438\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044E \u0432 \u0433\u043E\u0440\u043E\u0434\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955981
    m_Localized: "\u0414\u043E\u043C\u0435\u043D\u0438\u043A \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u0435\u0442
      \u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u044C \u0440\u043E\u0441\u0442\u0430
      \u043A\u043E\u043D\u0442\u0440\u0430\u0431\u0430\u043D\u0434\u044B \u0438 \u043F\u0438\u0440\u0430\u0442\u0441\u0442\u0432\u0430
      \u0438 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442 \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C
      \u0440\u0435\u0441\u0443\u0440\u0441\u044B \u043D\u0430 \u0441\u0440\u043E\u0447\u043D\u044B\u0439
      \u0440\u0435\u043C\u043E\u043D\u0442 \u0438 \u043C\u043E\u0434\u0435\u0440\u043D\u0438\u0437\u0430\u0446\u0438\u044E
      \u043A\u043E\u0440\u0430\u0431\u043B\u0435\u0439, \u0447\u0442\u043E\u0431\u044B
      \u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u043E \u0432\u0435\u0440\u043D\u0443\u0442\u044C
      \u0444\u043B\u043E\u0442 \u043A \u043E\u0445\u0440\u0430\u043D\u0435 \u043F\u043E\u0431\u0435\u0440\u0435\u0436\u044C\u044F.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955982
    m_Localized: "\u0414\u043E\u043C\u0435\u043D\u0438\u043A \u043E\u0431\u0435\u0441\u043F\u043E\u043A\u043E\u0435\u043D
      \u0442\u0435\u043C, \u0447\u0442\u043E \u0438\u0437-\u0437\u0430 \u043F\u043E\u0432\u0440\u0435\u0436\u0434\u0451\u043D\u043D\u044B\u0445
      \u0432\u0437\u043B\u0435\u0442\u043D\u044B\u0445 \u043F\u043E\u043B\u043E\u0441
      \u0438 \u0432\u0435\u0440\u0442\u043E\u043B\u0451\u0442\u043D\u044B\u0445 \u043F\u043B\u043E\u0449\u0430\u0434\u043E\u043A
      \u0430\u0432\u0438\u0430\u0446\u0438\u044F \u043D\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u0430
      \u0431\u044B\u0441\u0442\u0440\u043E \u0440\u0435\u0430\u0433\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u043D\u0430 \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u044B\u0435
      \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438, \u0438 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442
      \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
      \u0438\u043D\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443
      \u0430\u044D\u0440\u043E\u0434\u0440\u043E\u043C\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 5503791955983
    m_Localized: "\u0412\u0438\u0442\u043E \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442
